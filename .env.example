# Telegram Bot Token (get from @BotFather)
TELEGRAM_TOKEN=123456:ABC-...

# SOCKS5 Proxy for Telegram API (optional)
# Format: socks5://user:pass@host:port or socks5://host:port
# TELEGRAM_PROXY=socks5://127.0.0.1:1080

# Admin Telegram IDs (comma-separated, get from @userinfobot)
ADMIN_IDS=123456789,987654321

# Database settings
# Type: sqlite+aiosqlite, mysql+aiomysql, postgresql+asyncpg
DBTYPE=sqlite+aiosqlite
# For SQLite (default): DB_PATH is the path to the database file
DB_PATH=autorpg.db

# For MySQL/MariaDB (set DBTYPE=mysql+aiomysql)
# DBUSER=username
# DBPASS=password
# DBHOST=localhost
# DBPORT=3306
# DBNAME=autorpg

# Optional settings (with defaults)
OFFLINE_TIMEOUT=3600          # Seconds until player considered offline
GAME_INTERVAL=5               # Game tick interval in seconds
MONSTER_INTERVAL=1800         # Monster encounter interval in seconds
